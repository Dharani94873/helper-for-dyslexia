# Backend Environment Variables (for backend/.env)

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/dyslexia-helper
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dyslexia-helper?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS - Frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For production:
# ALLOWED_ORIGINS=https://your-frontend.netlify.app

# File Upload
MAX_FILE_SIZE=10485760
# 10MB = 10 * 1024 * 1024 bytes

# Storage (optional - for AWS S3)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=dyslexia-helper-uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes = 15 * 60 * 1000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend Environment Variables (for frontend)
# Create a config.js or use build-time replacement

# API_URL=http://localhost:5000
# For production:
# API_URL=https://your-backend.onrender.com
